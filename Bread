package Bakery;


public class Bread {
	private String name;
	private int price;
	private double weight;
	private int stack;
	private int selled;
	
	public Bread(String n,int p, double w, int st)
	{
		name=n;
		price=p;
		weight=w;
		stack=st;
		selled=0;
		
	}
	public void setName(String n)
	{
		name=n;
	}
	public void setWeight(double w)
	{
		weight=w;
	}
	public void setPrice(int p)
	{
		price=p;
	}
	public void addStack(int amount)
	{
		stack+=amount;
	}
	public void sell()
	{
		if(stack>0)
		{
			selled++;
			stack--;
		}
		else
			System.out.println("재고부족");
	}
	public void sell(int amount)
	{
		if(stack>0&&amount>0)
		{
			selled+=amount;
			stack-=amount;
		}
		else if(stack<=0)
			System.out.println("재고부족");
		else
			System.out.println("잘못된 입력");
	}
	public String getName() 
	{
        return name;
    }

    public int getPrice() 
    {
        return price;
    }

    public double getWeight() 
    {
        return weight;
    }

    public int getStack() 
    {
        return stack;
    }

    public int getSelled() 
    {
        return selled;
    }

    public void showInfo() 
    {
        System.out.println("상품: " + name);
        System.out.println("가격: " + price);
        System.out.println("무게: " + weight);
        System.out.println("재고: " + stack);
        System.out.println("판매량: " + selled);
    }

}
